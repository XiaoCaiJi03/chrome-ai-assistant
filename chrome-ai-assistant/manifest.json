{
  "manifest_version": 3,
  "name": "Text AI Assistant",
  "version": "1.0.0",
  "description": "选中文本，右键调用 AI 进行总结、翻译、解释等处理",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Text AI Assistant"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
